{
    "name": "stoolap/stoolap-php",
    "description": "Native PHP extension for Stoolap embedded SQL database",
    "type": "php-ext",
    "license": "Apache-2.0",
    "keywords": ["database", "sql", "embedded", "stoolap"],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Stoolap\\Tests\\": "tests/"
        }
    },
    "php-ext": {
        "extension-name": "stoolap",
        "configure-options": [
            {
                "name": "with-stoolap",
                "description": "Path to libstoolap directory"
            }
        ]
    },
    "scripts": {
        "test": "phpunit --testdox"
    }
}
